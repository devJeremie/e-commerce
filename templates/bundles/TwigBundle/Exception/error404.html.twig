{% extends 'base.html.twig' %}

{% block title %}Page introuvable{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light py-5">
    <div class="card border-0 shadow-sm text-center p-5" style="max-width: 500px; width: 100%; border-top: 4px solid #ef4444 !important;">

        <div class="mx-auto mb-4 rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center" style="width:80px; height:80px;">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="15" y1="9" x2="9" y2="15"/>
                <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
        </div>

        <p class="text-muted fw-semibold text-uppercase mb-1" style="font-size:.75rem; letter-spacing:.1em;">Erreur 404</p>
        <h1 class="h3 fw-bold mb-2">Page introuvable</h1>
        <p class="text-muted mb-4">
            La page que vous recherchez n'existe pas<br>ou a été déplacée.
        </p>

        <hr>

        <a href="{{ path('app_home') }}" class="btn btn-dark w-100 mb-2">Retour à l'accueil</a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary w-100">Page précédente</a>

    </div>
</div>
{% endblock %}
