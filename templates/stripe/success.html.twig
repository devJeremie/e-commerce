{% extends 'base.html.twig' %}

{% block title %}Paiement confirmé{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light py-5">
    <div class="card border-0 shadow-sm text-center p-5" style="max-width: 500px; width: 100%; border-top: 4px solid #22c55e !important;">

        <div class="mx-auto mb-4 rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width:80px; height:80px;">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
        </div>

        <h1 class="h3 fw-bold mb-2">Paiement confirmé</h1>
        <p class="text-muted mb-4">
            Votre commande a bien été enregistrée et votre paiement a été accepté.<br>
            Un e-mail de confirmation vous a été envoyé.
        </p>

        <hr>

        <div class="row g-3 mb-4 text-start">
            <div class="col-6">
                <div class="bg-light rounded p-3">
                    <div class="text-muted text-uppercase mb-1" style="font-size:.7rem; letter-spacing:.08em;">Statut</div>
                    <div class="fw-semibold text-success">✓ Payé</div>
                </div>
            </div>
            <div class="col-6">
                <div class="bg-light rounded p-3">
                    <div class="text-muted text-uppercase mb-1" style="font-size:.7rem; letter-spacing:.08em;">Date</div>
                    <div class="fw-semibold">{{ "now"|date("d/m/Y") }}</div>
                </div>
            </div>
        </div>

        <a href="{{ path('app_home') }}" class="btn btn-dark w-100 mb-2">Retour à l'accueil</a>
        <a href="{{ path('app_order') }}" class="btn btn-outline-secondary w-100">Voir mes commandes</a>

        <p class="text-muted mt-4 mb-0 small">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1">
                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            Paiement sécurisé par Stripe
        </p>
    </div>
</div>
{% endblock %}

